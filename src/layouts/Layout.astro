---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  variant?: string;
  noTrack?: boolean;
}

const {
  title = "The Market Matchup | Bolt Trades Private Discord",
  description = "Join Bolt's private Discord and trade alongside him in real time. Daily alerts, live calls, Q&A, and a community that moves together. Limited spots available.",
  variant,
  noTrack = false,
} = Astro.props;

// Get variant from props or middleware locals
const pageVariant = variant || (Astro.locals as any).variant || "a";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Plausible Analytics -->
    {!noTrack && (
      <>
        <script is:inline async src="https://plausible.io/js/pa-YPLa2h1LFcysKZcJpKnWZ.js"></script>
        <script is:inline>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()</script>
      </>
    )}
  </head>
  <body class="min-h-screen overflow-x-hidden" data-variant={pageVariant} data-no-track={noTrack ? "true" : undefined}>
    <slot />

    <!-- Vercel Analytics -->
    <Analytics />

    <!-- TikTok in-app browser: subtle instruction banner -->
    <script is:inline>
    (function() {
      var ua = navigator.userAgent || '';
      if (!/TikTok|BytedanceWebview|musical_ly/i.test(ua)) return;

      var banner = document.createElement('div');
      banner.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#0f0f23;color:#fff;padding:10px 40px 10px 16px;z-index:99998;text-align:center;border-bottom:1px solid #d4a74a;font-size:13px;line-height:1.4';
      banner.innerHTML = 'Tap <b style="color:#d4a74a">&#8942;</b> in the top right corner, then <b style="color:#d4a74a">Open in browser</b> for the best experience';

      var close = document.createElement('span');
      close.innerHTML = '&times;';
      close.style.cssText = 'position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:20px;cursor:pointer;opacity:.6;-webkit-tap-highlight-color:transparent';
      close.onclick = function() { banner.remove(); document.body.style.paddingTop = '0'; };
      banner.appendChild(close);

      document.body.appendChild(banner);
      document.body.style.paddingTop = '40px';
    })();
    </script>

    <!-- Fade-in scroll observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );

      document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
    </script>

  </body>
</html>
