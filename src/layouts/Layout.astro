---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  variant?: string;
  noTrack?: boolean;
}

const {
  title = "The Market Matchup | Bolt Trades Private Discord",
  description = "Join Bolt's private Discord and trade alongside him in real time. Daily alerts, live calls, Q&A, and a community that moves together. Limited spots available.",
  variant,
  noTrack = false,
} = Astro.props;

// Get variant from props or middleware locals
const pageVariant = variant || (Astro.locals as any).variant || "a";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Plausible Analytics -->
    {!noTrack && (
      <>
        <script is:inline async src="https://plausible.io/js/pa-YPLa2h1LFcysKZcJpKnWZ.js"></script>
        <script is:inline>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()</script>
      </>
    )}
  </head>
  <body class="min-h-screen overflow-x-hidden" data-variant={pageVariant} data-no-track={noTrack ? "true" : undefined}>
    <slot />

    <!-- Vercel Analytics -->
    <Analytics />

    <!-- TikTok in-app browser workaround -->
    <script is:inline>
    (function() {
      var ua = navigator.userAgent || '';
      if (!/TikTok|BytedanceWebview|musical_ly/i.test(ua)) return;

      // Create toast element
      var toast = document.createElement('div');
      toast.id = 'tiktok-toast';
      toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a2e;color:#fff;padding:14px 22px;border-radius:12px;font-size:15px;z-index:99999;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,.5);border:1px solid #d4a74a;max-width:90vw;display:none;line-height:1.4';
      document.body.appendChild(toast);

      function showToast(msg) {
        toast.innerHTML = msg;
        toast.style.display = 'block';
        clearTimeout(toast._t);
        toast._t = setTimeout(function() { toast.style.display = 'none'; }, 5000);
      }

      // Intercept all CTA clicks
      document.addEventListener('click', function(e) {
        var link = e.target.closest('[data-track="cta"]');
        if (!link) return;
        var url = link.href;
        if (!url) return;
        e.preventDefault();

        // Try clipboard API
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(function() {
            showToast('Link copied! Paste it in Safari or Chrome to complete your purchase.');
          }).catch(function() {
            showToast('Open in your browser:<br><b style="word-break:break-all;color:#d4a74a">' + url + '</b>');
          });
        } else {
          // Fallback: select + copy
          var inp = document.createElement('textarea');
          inp.value = url;
          inp.style.cssText = 'position:fixed;opacity:0';
          document.body.appendChild(inp);
          inp.select();
          try { document.execCommand('copy'); showToast('Link copied! Paste it in Safari or Chrome to complete your purchase.'); }
          catch(ex) { showToast('Open in your browser:<br><b style="word-break:break-all;color:#d4a74a">' + url + '</b>'); }
          document.body.removeChild(inp);
        }
      }, true);

      // Full-width banner with big tappable button
      var pageUrl = window.location.href;
      var banner = document.createElement('div');
      banner.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#0f0f23;color:#fff;padding:12px 16px 14px;z-index:99998;text-align:center;border-bottom:2px solid #d4a74a;box-shadow:0 2px 12px rgba(0,0,0,.6)';
      banner.innerHTML = '<div style="font-size:12px;margin-bottom:8px;opacity:.8">You\'re viewing this in TikTok</div>' +
        '<button id="tt-open-btn" style="display:block;width:100%;padding:14px 0;background:linear-gradient(135deg,#d4a74a,#b8860b);color:#000;font-weight:700;font-size:16px;border:none;border-radius:10px;cursor:pointer;letter-spacing:.3px;-webkit-tap-highlight-color:transparent">Open in Browser</button>';
      document.body.appendChild(banner);
      document.body.style.paddingTop = '82px';

      document.getElementById('tt-open-btn').addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        // Android: intent URL forces system browser
        if (/android/i.test(ua)) {
          window.location.href = 'intent://' + pageUrl.replace(/^https?:\/\//, '') + '#Intent;scheme=https;action=android.intent.action.VIEW;end';
          return;
        }
        // iOS: try x-safari, then window.open, then location
        window.location.href = 'x-safari-' + pageUrl;
        setTimeout(function() { window.open(pageUrl, '_system'); }, 300);
        setTimeout(function() { window.open(pageUrl, '_blank'); }, 600);
      });
    })();
    </script>

    <!-- Fade-in scroll observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );

      document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
    </script>

  </body>
</html>
