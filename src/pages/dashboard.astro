---
import Layout from "../layouts/Layout.astro";
import { getConversionStats, getRecentConversions } from "../lib/db/queries";

// Auth check
const token = (process.env.DASHBOARD_TOKEN || import.meta.env.DASHBOARD_TOKEN)?.trim();
const url = new URL(Astro.request.url);
const urlToken = url.searchParams.get("token");
const cookieToken = Astro.cookies.get("dashboard-auth")?.value;

let authenticated = !token;

if (token) {
  if (urlToken === token) {
    authenticated = true;
    Astro.cookies.set("dashboard-auth", token, {
      path: "/",
      maxAge: 60 * 60 * 24,
      httpOnly: true,
      sameSite: "lax",
    });
  } else if (cookieToken === token) {
    authenticated = true;
  }
}

if (!authenticated) {
  return new Response("Unauthorized — add ?token=YOUR_TOKEN to the URL", { status: 401 });
}

// Period
const period = url.searchParams.get("period") || "7";
const days = period === "all" ? 0 : parseInt(period) || 7;
const periodLabel = days === 0 ? "All Time" : `Last ${days} Days`;

// Build Plausible period params — use custom range so today is always included
const today = new Date();
const pad = (n: number) => String(n).padStart(2, "0");
const fmtDate = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
const todayStr = fmtDate(today);
function plausiblePeriodParams(): Record<string, string> {
  if (period === "all") return { period: "all" };
  const from = new Date(today);
  from.setDate(from.getDate() - days + 1);
  return { period: "custom", date: `${fmtDate(from)},${todayStr}` };
}
const periodParams = plausiblePeriodParams();

// Plausible API helper
const PLAUSIBLE_KEY = (process.env.PLAUSIBLE_API_KEY || import.meta.env.PLAUSIBLE_API_KEY)?.trim();
const SITE_ID = (process.env.PLAUSIBLE_SITE_ID || import.meta.env.PLAUSIBLE_SITE_ID || "themarketmatchup.com").trim();

async function plausibleFetch(endpoint: string, extra: Record<string, string> = {}) {
  const q = new URLSearchParams({ site_id: SITE_ID, ...periodParams, ...extra });
  const res = await fetch(`https://plausible.io/api/v1/stats/${endpoint}?${q}`, {
    headers: { Authorization: `Bearer ${PLAUSIBLE_KEY}` },
  });
  if (!res.ok) {
    const text = await res.text();
    throw new Error(`Plausible ${endpoint}: ${res.status} ${text}`);
  }
  return res.json();
}

// Fetch data
let pAggregate: any = null;
let pTimeseries: any[] = [];
let pDevices: any[] = [];
let pSources: any[] = [];
let pCountries: any[] = [];
let stripeStats: any = null;
let recentConversions: any[] = [];
let dataError = "";

try {
  const [agg, ts, dev, src, ctr, ss, rc] = await Promise.all([
    plausibleFetch("aggregate", { metrics: "pageviews,visitors,bounce_rate,visit_duration" }),
    plausibleFetch("timeseries", { metrics: "pageviews,visitors" }),
    plausibleFetch("breakdown", { property: "visit:device", metrics: "pageviews,visitors" }),
    plausibleFetch("breakdown", { property: "visit:source", metrics: "pageviews,visitors", limit: "8" }),
    plausibleFetch("breakdown", { property: "visit:country", metrics: "pageviews,visitors", limit: "8" }),
    getConversionStats(days),
    getRecentConversions(15),
  ]);
  pAggregate = agg.results;
  pTimeseries = ts.results || [];
  pDevices = dev.results || [];
  pSources = src.results || [];
  pCountries = ctr.results || [];
  stripeStats = ss;
  recentConversions = rc;
} catch (err: any) {
  console.error("Dashboard error:", err);
  dataError = err?.message || "Unknown error";
}

// Helpers
function fNum(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1) + "k";
  return String(Math.round(n));
}
function fPct(n: number): string { return n.toFixed(1) + "%"; }
function fDur(s: number): string {
  if (s < 60) return Math.round(s) + "s";
  return Math.floor(s / 60) + "m " + (Math.round(s) % 60) + "s";
}
function fMoney(n: number): string {
  return "$" + n.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function fDate(d: string | Date): string {
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
}

const pageviews = pAggregate?.pageviews?.value || 0;
const visitors = pAggregate?.visitors?.value || 0;
const bounceRate = pAggregate?.bounce_rate?.value || 0;
const visitDuration = pAggregate?.visit_duration?.value || 0;
const conversionRate = visitors > 0 && stripeStats ? (stripeStats.newSubscriptions / visitors * 100) : 0;

// Timeseries max for bar scaling
const maxPV = Math.max(...pTimeseries.map((r: any) => r.pageviews || 0), 1);
---

<Layout title="Dashboard | Market Matchup" noTrack={true} variant="a">
  <div class="min-h-screen bg-navy-950 text-slate-100">

    <!-- Header -->
    <header class="border-b border-navy-800 bg-navy-900/50 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/bolt-logo.png" alt="Bolt" class="w-8 h-8 rounded-full" />
          <h1 class="text-xl font-bold">Market Matchup <span class="text-gold-500">Analytics</span></h1>
        </div>
        <div class="flex items-center gap-2">
          {[
            { value: "7", label: "7d" },
            { value: "30", label: "30d" },
            { value: "all", label: "All" },
          ].map((p) => (
            <a
              href={`/dashboard?period=${p.value}&token=${urlToken || ""}`}
              class={`px-3 py-1.5 text-sm font-medium rounded-lg transition-colors ${
                period === p.value ? "bg-gold-500 text-navy-950" : "bg-navy-800 text-slate-400 hover:text-slate-200 hover:bg-navy-700"
              }`}
            >
              {p.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">

      {dataError ? (
        <div class="rounded-xl bg-navy-800 border border-bear/30 p-8 text-center">
          <h2 class="text-xl font-bold text-bear mb-2">Error Loading Data</h2>
          <p class="text-slate-400 text-sm font-mono">{dataError}</p>
        </div>
      ) : (
        <>
          <p class="text-sm text-slate-500">{periodLabel} · <span class="text-slate-400">Updated just now</span></p>

          {/* ── Row 1: KPI Cards ── */}
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Page Views</p>
              <p class="text-3xl font-black">{fNum(pageviews)}</p>
              <p class="text-xs text-slate-500 mt-1">Plausible</p>
            </div>
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Unique Visitors</p>
              <p class="text-3xl font-black">{fNum(visitors)}</p>
              <p class="text-xs text-slate-500 mt-1">Plausible</p>
            </div>
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Active Subscribers</p>
              <p class="text-3xl font-black text-bull">{stripeStats?.netSubscribers ?? "—"}</p>
              <p class="text-xs text-slate-500 mt-1">All time</p>
            </div>
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">MRR</p>
              <p class="text-3xl font-black text-gold-500">{stripeStats ? fMoney(stripeStats.mrr) : "—"}</p>
              <p class="text-xs text-slate-500 mt-1">Est. monthly</p>
            </div>
          </div>

          {/* ── Row 2: Engagement Metrics ── */}
          <div class="grid grid-cols-3 gap-4">
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Bounce Rate</p>
              <p class="text-2xl font-black">{fPct(bounceRate)}</p>
              <p class="text-xs text-slate-500 mt-1">Left without clicking</p>
            </div>
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Avg Visit Duration</p>
              <p class="text-2xl font-black">{fDur(visitDuration)}</p>
              <p class="text-xs text-slate-500 mt-1">Time on page</p>
            </div>
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Conversion Rate</p>
              <p class="text-2xl font-black text-bull">{fPct(conversionRate)}</p>
              <p class="text-xs text-slate-500 mt-1">New subs / visitors</p>
            </div>
          </div>

          {/* ── Row 3: Pageviews Sparkline ── */}
          {pTimeseries.length > 0 && (
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-6">
              <h2 class="text-lg font-bold mb-4">Pageviews Over Time</h2>
              <div class="flex items-end gap-1 h-24">
                {pTimeseries.map((r: any) => {
                  const h = Math.max((r.pageviews / maxPV) * 100, 2);
                  return (
                    <div class="flex-1 flex flex-col items-center gap-1 group relative">
                      <div
                        class="w-full bg-gold-500/60 rounded-t hover:bg-gold-500 transition-colors"
                        style={`height: ${h}%`}
                        title={`${r.date}: ${r.pageviews} views, ${r.visitors} visitors`}
                      ></div>
                    </div>
                  );
                })}
              </div>
              <div class="flex justify-between text-xs text-slate-600 mt-1">
                <span>{pTimeseries[0]?.date}</span>
                <span>{pTimeseries[Math.floor(pTimeseries.length / 2)]?.date}</span>
                <span>{pTimeseries[pTimeseries.length - 1]?.date}</span>
              </div>
            </div>
          )}

          {/* ── Row 4: Sources + Devices ── */}
          <div class="grid lg:grid-cols-2 gap-4">

            {/* Traffic Sources */}
            <div class="rounded-xl bg-navy-800 border border-navy-700 overflow-hidden">
              <div class="px-6 py-4 border-b border-navy-700">
                <h2 class="text-lg font-bold">Traffic Sources</h2>
              </div>
              <div class="divide-y divide-navy-700/50">
                {pSources.length === 0 ? (
                  <p class="px-6 py-8 text-center text-slate-500">No source data yet</p>
                ) : (
                  pSources.map((s: any, i: number) => {
                    const max = pSources[0]?.visitors || 1;
                    const w = (s.visitors / max) * 100;
                    return (
                      <div class="px-6 py-3 flex items-center gap-3">
                        <span class="text-xs text-slate-500 w-4">{i + 1}</span>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm font-medium truncate">{s.source || "Direct / None"}</p>
                          <div class="h-1.5 bg-navy-900 rounded mt-1">
                            <div class="h-full bg-gold-500/50 rounded" style={`width: ${w}%`}></div>
                          </div>
                        </div>
                        <div class="text-right">
                          <p class="text-sm font-bold">{fNum(s.visitors)}</p>
                          <p class="text-xs text-slate-500">{fNum(s.pageviews)} views</p>
                        </div>
                      </div>
                    );
                  })
                )}
              </div>
            </div>

            {/* Device Breakdown */}
            <div class="rounded-xl bg-navy-800 border border-navy-700 p-6">
              <h2 class="text-lg font-bold mb-4">Device Breakdown</h2>
              {pDevices.length === 0 ? (
                <p class="text-center text-slate-500 py-8">No device data yet</p>
              ) : (
                <div class="space-y-4">
                  {pDevices.map((d: any) => {
                    const total = pDevices.reduce((s: number, x: any) => s + x.visitors, 0);
                    const pct = total > 0 ? (d.visitors / total) * 100 : 0;
                    const icon = d.device === "Mobile" ? "📱" : d.device === "Tablet" ? "📟" : "🖥️";
                    const color = d.device === "Mobile" ? "bg-gold-500" : d.device === "Desktop" ? "bg-bull" : "bg-slate-500";
                    return (
                      <div>
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-sm font-medium">{icon} {d.device || "Unknown"}</span>
                          <span class="text-sm text-slate-400">{fNum(d.visitors)} ({fPct(pct)})</span>
                        </div>
                        <div class="h-3 bg-navy-900 rounded overflow-hidden">
                          <div class={`h-full rounded ${color}`} style={`width: ${Math.max(pct, 2)}%`}></div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          </div>

          {/* ── Row 5: Countries ── */}
          {pCountries.length > 0 && (
            <div class="rounded-xl bg-navy-800 border border-navy-700 overflow-hidden">
              <div class="px-6 py-4 border-b border-navy-700">
                <h2 class="text-lg font-bold">Top Countries</h2>
              </div>
              <div class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-navy-700">
                {pCountries.slice(0, 8).map((c: any) => (
                  <div class="px-6 py-4">
                    <p class="text-sm font-medium">{c.country}</p>
                    <p class="text-xl font-bold mt-1">{fNum(c.visitors)}</p>
                    <p class="text-xs text-slate-500">{fNum(c.pageviews)} views</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* ── Row 6: Stripe Summary ── */}
          {stripeStats && (
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
              <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">New Subs ({periodLabel})</p>
                <p class="text-3xl font-black text-bull">+{stripeStats.newSubscriptions}</p>
              </div>
              <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Cancellations ({periodLabel})</p>
                <p class="text-3xl font-black text-bear">-{stripeStats.cancellations}</p>
              </div>
              <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Period Revenue</p>
                <p class="text-3xl font-black text-gold-500">{fMoney(stripeStats.periodRevenue)}</p>
              </div>
              <div class="rounded-xl bg-navy-800 border border-navy-700 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Net Change</p>
                <p class={`text-3xl font-black ${stripeStats.newSubscriptions - stripeStats.cancellations >= 0 ? "text-bull" : "text-bear"}`}>
                  {stripeStats.newSubscriptions - stripeStats.cancellations >= 0 ? "+" : ""}{stripeStats.newSubscriptions - stripeStats.cancellations}
                </p>
              </div>
            </div>
          )}

          {/* ── Row 7: Recent Stripe Events ── */}
          <div class="rounded-xl bg-navy-800 border border-navy-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-navy-700 flex items-center justify-between">
              <h2 class="text-lg font-bold">Recent Stripe Events</h2>
              <span class="inline-flex items-center gap-1 text-xs text-bull">
                <span class="w-1.5 h-1.5 bg-bull rounded-full animate-pulse"></span>
                Live
              </span>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-slate-500 border-b border-navy-700 text-xs">
                    <th class="px-6 py-3 font-medium">Time</th>
                    <th class="px-6 py-3 font-medium">Type</th>
                    <th class="px-6 py-3 font-medium">Email</th>
                    <th class="px-6 py-3 font-medium text-right">Amount</th>
                  </tr>
                </thead>
                <tbody>
                  {recentConversions.length === 0 ? (
                    <tr>
                      <td colspan="4" class="px-6 py-8 text-center text-slate-500">No Stripe events yet</td>
                    </tr>
                  ) : (
                    recentConversions.map((c: any) => (
                      <tr class="border-b border-navy-700/30 hover:bg-navy-700/20">
                        <td class="px-6 py-3 text-slate-500 whitespace-nowrap text-xs">{fDate(c.created_at)}</td>
                        <td class="px-6 py-3">
                          <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-bold ${
                            c.event_type === "new_subscription" ? "bg-bull/10 text-bull" : "bg-bear/10 text-bear"
                          }`}>
                            {c.event_type === "new_subscription" ? "✓ New Sub" : "✗ Cancelled"}
                          </span>
                        </td>
                        <td class="px-6 py-3 text-slate-300">{c.customer_email || "—"}</td>
                        <td class="px-6 py-3 text-right font-bold text-gold-400">
                          {c.amount ? fMoney(c.amount) + "/mo" : "—"}
                        </td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </div>
        </>
      )}
    </main>
  </div>

  <script is:inline>
    // Auto-refresh every 60 seconds
    setTimeout(() => location.reload(), 60000);
  </script>
</Layout>
