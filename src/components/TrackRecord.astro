---
import { siteConfig } from "../data/config";

interface Props {
  stripeLink: string;
}

const { stripeLink } = Astro.props;
const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;
---

<section class="bg-navy-900">
  <div class="section-container">
    <div class="max-w-3xl mx-auto fade-in">
      <div class="rounded-2xl bg-navy-800 border border-navy-700 p-8 md:p-10 text-center">
        <!-- Stats row -->
        <div class="flex items-center justify-center gap-8 md:gap-16 mb-6">
          <div>
            <p class="text-4xl md:text-5xl font-black text-bull">26</p>
            <p class="text-sm text-slate-500 mt-1">Wins</p>
          </div>
          <div class="w-px h-12 bg-navy-700"></div>
          <div>
            <p class="text-4xl md:text-5xl font-black text-bear">5</p>
            <p class="text-sm text-slate-500 mt-1">Losses</p>
          </div>
          <div class="w-px h-12 bg-navy-700"></div>
          <div>
            <p class="text-4xl md:text-5xl font-black text-gold-gradient">84%</p>
            <p class="text-sm text-slate-500 mt-1">Win Rate</p>
          </div>
        </div>

        <p class="text-xs text-slate-500 mb-6">Since the start of March 2026</p>

        <p class="text-lg text-slate-300 leading-relaxed max-w-xl mx-auto mb-8">
          Losses happen — that's trading. We use stop losses to keep them small and
          <span class="text-gold-400 font-semibold">let our gains run big.</span>
        </p>

        <!-- CTA -->
        <a href={ctaUrl} class="btn-cta" data-track="cta" data-track-label="track_record_cta">
          {isSoldOut ? "Join the Waitlist" : "Start Trading With Us — Free Trial"}
        </a>
      </div>
    </div>
  </div>
</section>
