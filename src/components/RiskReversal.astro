---

<section class="bg-navy-950">
  <div class="section-container">
    <div class="max-w-2xl mx-auto text-center fade-in">
      <!-- Shield icon -->
      <div class="flex justify-center mb-6">
        <div class="w-16 h-16 rounded-full bg-navy-800 border border-navy-700 flex items-center justify-center">
          <svg class="w-8 h-8 text-bull" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
      </div>

      <h2 class="text-3xl md:text-4xl font-black tracking-tight leading-tight mb-4">
        Zero Risk. Full Control.
        <span class="text-gold-gradient"> Cancel Anytime.</span>
      </h2>

      <p class="text-lg text-slate-400 leading-relaxed">
        There are no contracts, no annual commitments, and no hoops to jump through.
        If The Market Matchup isn't for you, cancel with one click and you won't be charged again.
        You have nothing to lock in and nothing to lose.
      </p>

      <!-- Trust badges -->
      <div class="flex items-center justify-center gap-6 mt-8 text-slate-500">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          <span class="text-sm">Secure Stripe Checkout</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
          </svg>
          <span class="text-sm">Cancel with One Click</span>
        </div>
      </div>
    </div>
  </div>
</section>
