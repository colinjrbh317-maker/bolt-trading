---
import { siteConfig } from "../data/config";

interface Props {
  price: number;
  stripeLink: string;
}

const { price, stripeLink } = Astro.props;

const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;
---

<section class="bg-navy-950 relative overflow-hidden">
  <!-- Subtle gold gradient at top -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-gradient-to-b from-gold-500/5 to-transparent rounded-full blur-3xl"></div>

  <div class="section-container py-20 md:py-28 relative z-10">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight mb-6">
        The Next Alert Drops Tomorrow Morning.
        <span class="text-gold-gradient"> Be in the Room for $1.</span>
      </h2>

      <p class="text-lg text-slate-400 leading-relaxed mb-10 max-w-2xl mx-auto">
        <span data-spots-left>{spotsLeft} Spots</span> left. One community. The traders inside are already positioned.
        For just $1 you get full access for 24 hours — see the alerts, the community, everything. Then decide.
      </p>

      <a href={ctaUrl} class="btn-cta btn-cta-lg" data-track="cta" data-track-label="final_cta">
        {isSoldOut ? "Join the Waitlist" : "Try It for $1 — Full Access for 24 Hours"}
      </a>

      <p class="text-sm text-slate-500 mt-4" data-spots-remaining>
        Only <span class="text-gold-500 font-bold">{spotsLeft} spots</span> remaining — Just $1 to get inside
      </p>
    </div>
  </div>
</section>
