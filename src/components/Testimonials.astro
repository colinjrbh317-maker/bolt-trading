---
import { screenshotTestimonials } from "../data/testimonials";
import { siteConfig } from "../data/config";

interface Props {
  stripeLink: string;
}

const { stripeLink } = Astro.props;
const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;
---

<section class="bg-navy-900">
  <div class="section-container">
    <div class="text-center mb-10 fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
        Don't Take Our Word for It.
        <span class="text-gold-gradient"> Real Screenshots. Real Gains.</span>
      </h2>
    </div>

    <!-- Horizontal scroll on mobile, 3-col grid on desktop -->
    <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory md:grid md:grid-cols-3 md:overflow-visible md:pb-0 -mx-4 px-4 md:mx-0 md:px-0 scrollbar-hide">
      {screenshotTestimonials.map((t) => (
        <div class="snap-center shrink-0 w-72 md:w-auto fade-in">
          <div class="rounded-xl overflow-hidden border border-navy-700 bg-navy-800">
            <img
              src={t.imagePath}
              alt={t.alt}
              class="w-full object-contain"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 fade-in">
      <a href={ctaUrl} class="btn-cta" data-track="cta" data-track-label="testimonials_cta">
        {isSoldOut ? "Join the Waitlist" : "Join These Traders — $40/mo"}
      </a>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
