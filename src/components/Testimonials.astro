---
import { screenshotTestimonials } from "../data/testimonials";
import { siteConfig } from "../data/config";

interface Props {
  stripeLink: string;
}

const { stripeLink } = Astro.props;
const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;
---

<section class="bg-navy-900">
  <div class="section-container">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
        Don't Take Our Word for It.
        <span class="text-gold-gradient"> Real Screenshots. Real Gains.</span>
      </h2>
      <p class="text-slate-400 mt-4 text-lg max-w-2xl mx-auto">
        These are actual screenshots from our Discord members — unedited, unfiltered.
      </p>
    </div>

    <!-- Grid of testimonial screenshots -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      {screenshotTestimonials.map((t) => (
        <div class="rounded-xl overflow-hidden border border-navy-700 bg-navy-800 fade-in">
          <img
            src={t.imagePath}
            alt={t.alt}
            class="w-full object-contain"
            loading="lazy"
          />
          <div class="p-3 text-center">
            <p class="text-sm font-bold text-gold-400">{t.highlight}</p>
            <p class="text-xs text-slate-500 mt-1">@{t.username}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 fade-in">
      <a href={ctaUrl} class="btn-cta">
        {isSoldOut ? "Join the Waitlist" : "Join These Traders — $40/mo"}
      </a>
    </div>
  </div>
</section>
