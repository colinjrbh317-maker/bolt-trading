---
import { siteConfig } from "../data/config";

interface Props {
  price: number;
  stripeLink: string;
}

const { price, stripeLink } = Astro.props;

const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;
const ctaText = isSoldOut ? "Join the Waitlist" : `Join The Market Matchup — $${price}/mo`;
---

<section class="relative bg-candlestick min-h-[90vh] flex items-center">
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-950/60 via-navy-900/80 to-navy-900"></div>

  <div class="section-container relative z-10 text-center w-full">
    <!-- Logo -->
    <div class="flex justify-center mb-8">
      <img
        src="/bolt-logo.png"
        alt="Bolt Trades"
        width="100"
        height="100"
        class="w-20 h-20 md:w-24 md:h-24 rounded-full"
      />
    </div>

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-navy-800 border border-navy-700">
      <span class="pulse-dot"></span>
      <span class="text-sm font-medium text-slate-300">
        {siteConfig.memberCount}+ active traders inside right now
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-6 max-w-4xl mx-auto">
      Get the Alerts
      <span class="text-gold-gradient"> Before </span>
      They Hit TikTok.
    </h1>

    <!-- Subheadline -->
    <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Join Bolt's private Discord and trade alongside him in real time — daily alerts,
      live calls, and a community that actually moves together.
    </p>

    <!-- CTA -->
    <div class="flex flex-col items-center gap-4">
      <a href={ctaUrl} class="btn-cta text-base md:text-lg">
        {ctaText}
      </a>

      {!isSoldOut && (
        <p class="text-sm text-slate-500">
          Only <span class="text-gold-500 font-bold">{spotsLeft} spots</span> remaining — Cancel anytime
        </p>
      )}
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-navy-900 to-transparent"></div>
</section>
