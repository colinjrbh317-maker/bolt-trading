---
const faqs = [
  {
    question: "What exactly is The Market Matchup?",
    answer:
      "It's Bolt's private Discord server for day traders. Inside, you get daily trade alerts, live call sessions, direct Q&A with Bolt, and access to a community of active traders. Think of it as your trading floor — without the Wall Street address.",
  },
  {
    question: "Do I need trading experience to join?",
    answer:
      "You should have a basic understanding of how the stock market works and how to place a trade. This isn't a \"start from zero\" course — it's a live trading environment. If you've been following Bolt's content and understand the basics, you'll fit right in.",
  },
  {
    question: "What kind of trades does Bolt alert?",
    answer:
      "Bolt focuses on day trades — primarily equities and options. Alerts include entry, target, and stop levels along with his reasoning. You'll see the setup as he takes it, in real time.",
  },
  {
    question: "Is this financial advice?",
    answer:
      "No. The Market Matchup is an educational community. Bolt shares what he's trading and why, but every trade you make is your own decision. Nothing shared inside the Discord is financial advice. Always do your own due diligence and only trade with money you can afford to lose.",
  },
  {
    question: "Why are spots limited?",
    answer:
      "Because a 50,000-person Discord helps no one. Bolt keeps the community small so he can actually interact with members — answer questions, give feedback, and keep the quality high. Limited spots mean a better experience for everyone inside.",
  },
  {
    question: "Can I really cancel anytime?",
    answer:
      "Yes. One click. No phone calls, no emails, no \"retention specialists.\" You cancel, your billing stops. No questions asked.",
  },
  {
    question: "When do I get access after I join?",
    answer:
      "Immediately. Once your payment processes, you'll receive a Discord invite link and you're in. If it's a market day, you can start trading with the community that same session.",
  },
];
---

<section class="bg-navy-900">
  <div class="section-container">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
        Frequently Asked
        <span class="text-gold-gradient"> Questions</span>
      </h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-4 fade-in">
      {faqs.map((faq, i) => (
        <details class="group bg-navy-800 rounded-xl border border-navy-700 overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer p-6 text-left font-bold text-slate-100 hover:text-gold-500 transition-colors">
            <span>{faq.question}</span>
            <svg
              class="w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform shrink-0 ml-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-slate-400 leading-relaxed -mt-2">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
