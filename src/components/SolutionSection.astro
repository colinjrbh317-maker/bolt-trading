---
import { siteConfig } from "../data/config";

interface Props {
  stripeLink: string;
}

const { stripeLink } = Astro.props;
const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;
---

<section class="bg-navy-900">
  <div class="section-container">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <!-- Market Matchup Logo -->
      <div class="flex justify-center mb-8">
        <img
          src="/market-matchup-logo.png"
          alt="The Market Matchup"
          width="200"
          height="200"
          class="w-40 h-40 md:w-48 md:h-48 rounded-2xl"
        />
      </div>

      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight mb-6">
        This Is the Room
        <span class="text-gold-gradient"> Where It Happens.</span>
      </h2>

      <p class="text-lg md:text-xl text-slate-400 leading-relaxed mb-4">
        The ultimate Discord for traders who play shares, options, catch momentum, and stay
        sharp in any market. Whether you're a seasoned investor or just getting started,
        this is where knowledge meets execution — with stock alerts, options callouts,
        education channels, and 400+ members who genuinely want to see each other win.
      </p>

      <!-- Wall Street Veteran Badge -->
      <div class="flex justify-center mt-8 mb-6">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-navy-800 border border-navy-700">
          <svg class="w-5 h-5 text-gold-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <span class="text-sm font-medium text-slate-300">
            Led by Bolt + a <span class="text-gold-400 font-bold">Wall Street veteran</span> with 30+ years of trading experience
          </span>
        </div>
      </div>

      <!-- Trading Styles -->
      <div class="flex flex-wrap justify-center gap-3 mb-6">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gold-500/10 text-gold-400 border border-gold-500/20">Options</span>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gold-500/10 text-gold-400 border border-gold-500/20">Shares</span>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gold-500/10 text-gold-400 border border-gold-500/20">Swing Trades</span>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-bull/10 text-bull border border-bull/20">Beginners Welcome</span>
      </div>

      <p class="text-lg md:text-xl text-slate-300 font-medium mb-8">
        We trade options, shares, and long-term swings. Whether you're brand new or experienced, there's a place for you.
        Members stick around for the culture, not just the charts — real friendships, real connections, real growth.
      </p>

      <!-- Real Alert Example -->
      <div class="max-w-md mx-auto mb-8">
        <p class="text-sm text-slate-500 mb-3">Here's what an actual alert looks like:</p>
        <div class="rounded-xl overflow-hidden border border-navy-700 bg-navy-800">
          <img
            src="/alerts/bolt-ctmx-alert.jpg"
            alt="Bolt Trades posting CTMX 3/20 $8 PUT alert to @everyone in Discord"
            class="w-full object-contain"
            loading="lazy"
          />
        </div>
      </div>

      <!-- CTA -->
      <a href={ctaUrl} class="btn-cta" data-track="cta" data-track-label="solution_cta">
        {isSoldOut ? "Join the Waitlist" : "Get Inside — $40/mo"}
      </a>
    </div>
  </div>
</section>
