---
import { siteConfig } from "../data/config";

interface Props {
  stripeLink: string;
}

const { stripeLink } = Astro.props;
const spotsLeft = siteConfig.spots.total - siteConfig.spots.claimed;
const isSoldOut = spotsLeft <= 0;
const ctaUrl = isSoldOut ? siteConfig.waitlistUrl : stripeLink;

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: "Stock & Options Alerts",
    description:
      "Shares plays, options callouts, and Bullseye bot alerts — all dropped in real time before they hit TikTok. Bolt and the team post entries, targets, and stops so you see setups as they happen.",
    color: "text-gold-500",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: "Education & Strategy",
    description:
      "Techsan — our dedicated options trader — runs accountability-tracked channels covering options education, market structure, and risk management. January: 80% success rate. February: 79%. Learn from someone who posts every trade publicly.",
    color: "text-bull",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>`,
    title: "Ask Anything — Q&A Channel",
    description:
      "No question is too basic. The stock-questions channel is where beginners and experienced traders alike ask about setups, tickers, entries, and strategy — and actually get answers.",
    color: "text-gold-400",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: "A Community That Actually Cares",
    description:
      "400+ members who genuinely want to see each other win. Daily market recaps, constant giveaways, off-topic channels where real friendships form. People stay for the culture, not just the charts.",
    color: "text-bull",
  },
];
---

<section class="bg-navy-950">
  <div class="section-container">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
        Everything You Get Inside
        <span class="text-gold-gradient"> The Market Matchup</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
      {features.map((feature) => (
        <div class="card-feature fade-in">
          <div class={`mb-4 ${feature.color}`} set:html={feature.icon} />
          <h3 class="text-xl font-bold text-slate-100 mb-3">{feature.title}</h3>
          <p class="text-slate-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 fade-in">
      <a href={ctaUrl} class="btn-cta" data-track="cta" data-track-label="features_cta">
        {isSoldOut ? "Join the Waitlist" : "Get All of This — $49.99/mo"}
      </a>
    </div>
  </div>
</section>
