---
const boltsGains = [
  { src: "/gains/IMG_7918.jpg", alt: "QQQ $602 Call closed for +$4,590 profit, +30%", label: "QQQ Call", pct: "+$4,590" },
  { src: "/gains/IMG_7921.jpg", alt: "SPXW 6645 Put closed for +$2,060 realized profit", label: "SPXW Put", pct: "+$2,060" },
  { src: "/gains/IMG_7919.PNG", alt: "IWM options position up +$2,130, +100.95%", label: "IWM Options", pct: "+100%" },
];

const memberGains = [
  { src: "/gains/IMG_7928.jpg", alt: "Portfolio up 315.62% in one week", label: "Weekly portfolio", pct: "+315%" },
];
---

<section class="bg-navy-950">
  <div class="section-container">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
        Real Trades.
        <span class="text-gold-gradient"> Real Results.</span>
      </h2>
      <p class="text-slate-400 mt-4 text-lg max-w-2xl mx-auto">
        Screenshots straight from the Discord. Wins, losses, and everything in between.
      </p>
    </div>

    <!-- Bolt's Trades -->
    <div class="mb-12">
      <h3 class="text-lg font-bold text-slate-200 mb-4 fade-in">
        <span class="text-gold-500">Bolt's Alerts</span> — These are the setups you get
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {boltsGains.map((g) => (
          <div class="rounded-xl overflow-hidden border border-navy-700 bg-navy-800 fade-in">
            <img src={g.src} alt={g.alt} class="w-full object-contain bg-navy-900" loading="lazy" />
            <div class="p-3 flex justify-between items-center">
              <span class="text-sm text-slate-300">{g.label}</span>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-bull/10 text-bull border border-bull/20">{g.pct}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Member Gains -->
    <div class="mb-12">
      <h3 class="text-lg font-bold text-slate-200 mb-4 fade-in">
        <span class="text-bull">Member Gains</span> — The community wins together
      </h3>
      <div class="max-w-sm mx-auto">
        <div class="rounded-xl overflow-hidden border border-navy-700 bg-navy-800 fade-in">
          <img src={memberGains[0].src} alt={memberGains[0].alt} class="w-full object-contain bg-navy-900" loading="lazy" />
          <div class="p-3 flex justify-between items-center">
            <span class="text-sm text-slate-300">{memberGains[0].label}</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-bull/10 text-bull border border-bull/20">{memberGains[0].pct}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Stop Loss / Honesty -->
    <div class="max-w-sm mx-auto">
      <h3 class="text-lg font-bold text-slate-200 mb-4 text-center fade-in">
        <span class="text-bear">We Keep Losses Small</span>
      </h3>
      <div class="rounded-xl overflow-hidden border border-navy-700 bg-navy-800 fade-in">
        <img src="/gains/IMG_7922.jpg" alt="BIAF stop loss triggered at -$98.50 (-7.89%) while MARA calls profit" class="w-full object-contain bg-navy-900" loading="lazy" />
        <div class="p-3 text-center">
          <p class="text-sm text-slate-400">Stop loss triggered at <span class="text-bear font-bold">-7.89%</span> — while wins keep running</p>
        </div>
      </div>
    </div>
  </div>
</section>
